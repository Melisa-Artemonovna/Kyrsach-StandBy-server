@model List<Kourse_project_BD_vav.Models.PropertyReservation>

@{
    ViewData["Title"] = User.IsInRole("Realtor") ? "Заявки на просмотр объектов" : "Бронирования просмотров";
}

<!DOCTYPE html>
<html>
<head>
    <title>@ViewData["Title"]</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #e0e0e0 0%, #bdbdbd 100%);
            min-height: 100vh;
            padding: 20px;
        }

        .container {
            max-width: 1200px;
            margin: 0 auto;
        }

        /* Шапка */
        .header {
            background: white;
            padding: 20px 30px;
            border-radius: 15px;
            margin-bottom: 25px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            box-shadow: 0 4px 20px rgba(0,0,0,0.1);
            border-left: 5px solid #6c757d;
            animation: slideDown 0.5s ease;
        }

        @@keyframes slideDown {
            from {
                opacity: 0;
                transform: translateY(-20px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .back-btn {
            padding: 10px 20px;
            background: #f8f9fa;
            color: #495057;
            text-decoration: none;
            border-radius: 8px;
            font-weight: 600;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            transition: all 0.3s ease;
        }

        .back-btn:hover {
            background: #e9ecef;
            transform: translateX(-3px);
            box-shadow: 0 2px 8px rgba(0,0,0,0.1);
        }

        /* Уведомления */
        .alert {
            padding: 15px 20px;
            border-radius: 10px;
            margin-bottom: 20px;
            font-weight: 500;
            animation: slideDown 0.5s ease;
        }

        .alert-success {
            background: #d4edda;
            color: #155724;
            border: 1px solid #c3e6cb;
        }

        .alert-error {
            background: #f8d7da;
            color: #721c24;
            border: 1px solid #f5c6cb;
        }

        /* Основной контент */
        .content-card {
            background: white;
            border-radius: 15px;
            overflow: hidden;
            box-shadow: 0 4px 30px rgba(0,0,0,0.1);
            margin-bottom: 30px;
            animation: slideDown 0.7s ease;
        }

        /* Таблица */
        .table-container {
            overflow-x: auto;
        }

        table {
            width: 100%;
            border-collapse: collapse;
        }

        thead {
            background: #343a40;
            color: white;
        }

        th {
            padding: 15px;
            text-align: left;
            font-weight: 600;
            text-transform: uppercase;
            font-size: 12px;
            letter-spacing: 1px;
        }

        tbody tr {
            border-bottom: 1px solid #e9ecef;
            transition: all 0.2s ease;
        }

        tbody tr:hover {
            background: #f8f9fa;
            transform: scale(1.01);
        }

        td {
            padding: 15px;
        }

        .badge {
            background: #6c757d;
            color: white;
            padding: 5px 12px;
            border-radius: 12px;
            font-size: 12px;
            font-weight: 500;
            display: inline-block;
        }

        .badge-success {
            background: #6c757d;
        }

        .badge-info {
            background: #495057;
        }

        .badge-warning {
            background: #95a5a6;
        }

        /* Кнопки */
        .btn {
            padding: 8px 15px;
            border-radius: 8px;
            font-weight: 500;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 6px;
            border: none;
            cursor: pointer;
            transition: all 0.3s ease;
            font-size: 14px;
        }

        .btn-outline-primary {
            background: transparent;
            color: #495057;
            border: 2px solid #6c757d;
        }

        .btn-outline-primary:hover {
            background: #6c757d;
            color: white;
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(108, 117, 125, 0.3);
        }

        .btn-outline-success {
            background: transparent;
            color: #6c757d;
            border: 2px solid #6c757d;
        }

        .btn-outline-success:hover {
            background: #6c757d;
            color: white;
            transform: translateY(-2px);
        }

        .btn-outline-danger {
            background: transparent;
            color: #495057;
            border: 2px solid #6c757d;
        }

        .btn-outline-danger:hover {
            background: #6c757d;
            color: white;
            transform: translateY(-2px);
        }

        .btn-group {
            display: flex;
            gap: 5px;
        }

        /* Пустое состояние */
        .empty-state {
            background: white;
            padding: 60px 40px;
            text-align: center;
            border-radius: 15px;
            margin: 40px 0;
            box-shadow: 0 4px 20px rgba(0,0,0,0.1);
            animation: slideDown 0.8s ease;
        }

        .empty-icon {
            font-size: 64px;
            margin-bottom: 20px;
            opacity: 0.5;
            color: #6c757d;
        }

        .empty-title {
            color: #6c757d;
            margin-bottom: 15px;
            font-size: 24px;
        }

        .empty-text {
            color: #6c757d;
            max-width: 500px;
            margin: 0 auto;
            line-height: 1.6;
        }

        .contact-info {
            font-size: 13px;
            color: #6c757d;
        }

        .contact-info i {
            margin-right: 5px;
            width: 16px;
        }

        a {
            color: #495057;
            text-decoration: none;
            font-weight: 500;
            transition: color 0.3s;
        }

        a:hover {
            color: #343a40;
            text-decoration: underline;
        }
    </style>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
</head>
<body>
    <div class="container">
        <!-- Шапка -->
        <div class="header">
            <div>
                <h1 style="margin: 0; color: #343a40; display: flex; align-items: center; gap: 10px;">
                    <i class="bi bi-calendar-check"></i> @ViewData["Title"]
                </h1>
                @if (User.IsInRole("Realtor"))
                {
                    <p style="color: #6c757d; font-size: 14px; margin-top: 5px;">Здесь отображаются клиенты, которые оставили заявку на резервирование ваших объектов недвижимости</p>
                }
            </div>
            <a href="/Home/Dashboard" class="back-btn">
                <i class="bi bi-arrow-left"></i> Назад в кабинет
            </a>
        </div>

        <!-- Уведомления -->
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success">
                <i class="bi bi-check-circle"></i> @TempData["SuccessMessage"]
            </div>
        }

        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-error">
                <i class="bi bi-exclamation-triangle"></i> @TempData["ErrorMessage"]
            </div>
        }

        @if (Model == null || !Model.Any())
        {
            <div class="empty-state">
                <div class="empty-icon">
                    <i class="bi bi-calendar-x"></i>
                </div>
                <h3 class="empty-title">
                    @if (User.IsInRole("Realtor"))
                    {
                        <text>У вас пока нет заявок на резервирование</text>
                    }
                    else
                    {
                        <text>У вас пока нет активных резервирований</text>
                    }
                </h3>
            </div>
        }
        else
        {
            <!-- Таблица резервирований -->
            <div class="content-card">
                <div class="table-container">
                    <table>
                        <thead>
                            <tr>
                                <th>Объект</th>
                                <th>Дата бронирования</th>
                                <th>Дата истечения</th>
                                <th>Статус</th>
                                @if (User.IsInRole("Admin") || User.IsInRole("Realtor"))
                                {
                                    <th>Клиент</th>
                                    <th>Контакты</th>
                                }
                                @if (!User.IsInRole("Realtor"))
                                {
                                    <th>Действия</th>
                                }
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var reservation in Model)
                            {
                                <tr>
                                    <td>
                                        @if (reservation.Property != null)
                                        {
                                            <a href="/Property/Details/@reservation.Property.property_id">
                                                @reservation.Property.address
                                            </a>
                                        }
                                        else
                                        {
                                            <span style="color: #6c757d;">Объект удален</span>
                                        }
                                    </td>
                                    <td>@reservation.reservation_date.ToString("dd.MM.yyyy HH:mm")</td>
                                    <td>@reservation.expiry_date.ToString("dd.MM.yyyy HH:mm")</td>
                                    <td>
                                        @if (reservation.status == "Active")
                                        {
                                            <span class="badge badge-success">Активен</span>
                                        }
                                        else if (reservation.status == "Completed")
                                        {
                                            <span class="badge badge-info">Завершен</span>
                                        }
                                        else
                                        {
                                            <span class="badge badge-warning">@reservation.status</span>
                                        }
                                    </td>
                                    @if (User.IsInRole("Admin") || User.IsInRole("Realtor"))
                                    {
                                        <td>
                                            @if (reservation.Client != null)
                                            {
                                                <strong>@reservation.Client.full_name</strong>
                                            }
                                        </td>
                                        <td>
                                            @if (reservation.Client != null)
                                            {
                                                <div class="contact-info">
                                                    <div><i class="bi bi-telephone"></i> @reservation.Client.phone_number</div>
                                                    <div><i class="bi bi-envelope"></i> @reservation.Client.email</div>
                                                </div>
                                            }
                                        </td>
                                    }
                                    @if (!User.IsInRole("Realtor"))
                                    {
                                        <td>
                                            <div class="btn-group">
                                                <a href="/PropertyReservation/Edit/@reservation.reservation_id" class="btn btn-outline-primary">
                                                    <i class="bi bi-pencil"></i>
                                                </a>

                                                @if (User.IsInRole("Admin"))
                                                {
                                                    <form asp-action="Complete" method="post" style="display: inline;">
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="id" value="@reservation.reservation_id" />
                                                        <button type="submit" class="btn btn-outline-success"
                                                                onclick="return confirm('Отметить как завершенное?')">
                                                            <i class="bi bi-check-circle"></i>
                                                        </button>
                                                    </form>
                                                }

                                                <form asp-action="Delete" method="post" style="display: inline;">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="id" value="@reservation.reservation_id" />
                                                    <button type="submit" class="btn btn-outline-danger"
                                                            onclick="return confirm('Вы уверены, что хотите отменить бронирование?')">
                                                        <i class="bi bi-trash"></i>
                                                    </button>
                                                </form>
                                            </div>
                                        </td>
                                    }
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    </div>

    <script>
        // Автоматическое скрытие уведомлений
        setTimeout(function() {
            var alerts = document.querySelectorAll('.alert');
            alerts.forEach(function(alert) {
                alert.style.opacity = '0';
                setTimeout(function() {
                    if (alert.parentNode) {
                        alert.parentNode.removeChild(alert);
                    }
                }, 300);
            });
        }, 5000);
    </script>
</body>
</html>
