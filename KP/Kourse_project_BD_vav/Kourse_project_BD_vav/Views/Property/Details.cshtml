@model Kourse_project_BD_vav.Models.Property
@{
    ViewData["Title"] = "Детали объекта";
}

<!DOCTYPE html>
<html>
<head>
    <title>@ViewData["Title"]</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #e0e0e0 0%, #bdbdbd 100%);
            min-height: 100vh;
            padding: 20px;
        }

        .container {
            max-width: 1200px;
            margin: 0 auto;
        }

        /* Шапка */
        .header {
            background: white;
            padding: 20px 30px;
            border-radius: 15px;
            margin-bottom: 25px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            box-shadow: 0 4px 20px rgba(0,0,0,0.1);
            border-left: 5px solid #6c757d;
            animation: slideDown 0.5s ease;
        }

        .back-btn {
            padding: 10px 20px;
            background: #f8f9fa;
            color: #495057;
            text-decoration: none;
            border-radius: 8px;
            font-weight: 600;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            transition: all 0.3s ease;
        }

        .back-btn:hover {
            background: #e9ecef;
            transform: translateX(-3px);
            box-shadow: 0 2px 8px rgba(0,0,0,0.1);
        }

        @@keyframes slideDown {
            from {
                opacity: 0;
                transform: translateY(-20px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* Основной контент */
        .property-detail {
            background: white;
            border-radius: 15px;
            overflow: hidden;
            box-shadow: 0 4px 30px rgba(0,0,0,0.1);
            margin-bottom: 30px;
        }

        /* Галерея */
        .gallery {
            position: relative;
            height: 400px;
            overflow: hidden;
        }

        .main-image {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .image-placeholder {
            width: 100%;
            height: 100%;
            background: linear-gradient(135deg, #6c757d, #495057);
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 60px;
        }

        .image-counter {
            position: absolute;
            bottom: 20px;
            right: 20px;
            background: rgba(0,0,0,0.7);
            color: white;
            padding: 8px 15px;
            border-radius: 20px;
            font-size: 14px;
        }

        /* Информация */
        .property-info {
            padding: 30px;
        }

        .property-header {
            margin-bottom: 25px;
            border-bottom: 2px solid #f8f9fa;
            padding-bottom: 20px;
        }

        .property-address {
            font-size: 24px;
            font-weight: 700;
            color: #2c3e50;
            margin-bottom: 10px;
        }

        .property-price {
            font-size: 32px;
            font-weight: 800;
            color: #6c757d;
            margin-bottom: 15px;
        }

        .property-meta {
            display: flex;
            gap: 15px;
            flex-wrap: wrap;
        }

        .meta-item {
            background: #f8f9fa;
            padding: 10px 20px;
            border-radius: 10px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .meta-label {
            font-size: 12px;
            color: #7f8c8d;
            text-transform: uppercase;
        }

        .meta-value {
            font-weight: 600;
            color: #2c3e50;
        }

        /* Описание */
        .property-description {
            margin: 30px 0;
            padding: 25px;
            background: #f8f9fa;
            border-radius: 10px;
        }

        .description-title {
            font-size: 18px;
            font-weight: 600;
            color: #2c3e50;
            margin-bottom: 15px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .description-text {
            line-height: 1.8;
            color: #495057;
            font-size: 15px;
            white-space: pre-line;
        }

        /* Характеристики */
        .property-specs {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 20px;
            margin: 30px 0;
        }

        .spec-card {
            background: white;
            border: 2px solid #f8f9fa;
            border-radius: 10px;
            padding: 20px;
            text-align: center;
            transition: all 0.3s ease;
        }

            .spec-card:hover {
                border-color: #6c757d;
                transform: translateY(-5px);
            }

        .spec-icon {
            font-size: 32px;
            color: #6c757d;
            margin-bottom: 10px;
        }

        .spec-title {
            font-size: 14px;
            color: #7f8c8d;
            text-transform: uppercase;
            margin-bottom: 5px;
        }

        .spec-value {
            font-size: 18px;
            font-weight: 700;
            color: #2c3e50;
        }

        /* Кнопки действий */
        .action-buttons {
            display: flex;
            gap: 15px;
            flex-wrap: wrap;
            padding-top: 30px;
            border-top: 2px solid #f8f9fa;
        }

        .btn {
            padding: 12px 25px;
            border-radius: 10px;
            font-weight: 600;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 10px;
            border: none;
            cursor: pointer;
            transition: all 0.3s ease;
            font-size: 15px;
        }

        .btn-primary {
            background: linear-gradient(135deg, #6c757d, #495057);
            color: white;
        }

            .btn-primary:hover {
                transform: translateY(-3px);
                box-shadow: 0 6px 20px rgba(108, 117, 125, 0.4);
            }

        .btn-secondary {
            background: #f8f9fa;
            color: #495057;
            border: 2px solid #e9ecef;
        }

            .btn-secondary:hover {
                background: #e9ecef;
            }

        .btn-danger {
            background: linear-gradient(135deg, #6c757d, #495057);
            color: white;
        }

        .btn-danger:hover {
            transform: translateY(-3px);
            box-shadow: 0 6px 20px rgba(108, 117, 125, 0.3);
        }

        .btn-success {
            background: linear-gradient(135deg, #6c757d, #495057);
            color: white;
        }

        .btn-success:hover {
            transform: translateY(-3px);
            box-shadow: 0 6px 20px rgba(108, 117, 125, 0.3);
        }

        /* Статус */
        .property-status {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 10px 20px;
            border-radius: 25px;
            font-weight: 600;
            margin-left: auto;
        }

        .status-available {
            background: #d4edda;
            color: #155724;
        }

        .status-sold {
            background: #f8d7da;
            color: #721c24;
        }

        /* Уведомления */
        .alert {
            padding: 15px 20px;
            border-radius: 10px;
            margin-bottom: 20px;
            font-weight: 500;
        }

        .alert-success {
            background: #d4edda;
            color: #155724;
            border: 1px solid #c3e6cb;
        }

        .alert-error {
            background: #f8d7da;
            color: #721c24;
            border: 1px solid #f5c6cb;
        }
    </style>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
</head>
<body>
    <div class="container">
        <!-- Уведомления -->
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success">
                <i class="bi bi-check-circle"></i> @TempData["SuccessMessage"]
            </div>
        }

        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-error">
                <i class="bi bi-exclamation-triangle"></i> @TempData["ErrorMessage"]
            </div>
        }

        <!-- Шапка -->
        <div class="header">
            <a href="/Property" class="back-btn">
                <i class="bi bi-arrow-left"></i> Назад к списку
            </a>
            <h1><i class="bi bi-house-door"></i> Детали объекта</h1>
        </div>

        <!-- Основной контент -->
        <div class="property-detail">
            <!-- Галерея -->
            <div class="gallery">
                @if (!string.IsNullOrEmpty(Model.main_image_url))
                {
                    <img src="@Model.main_image_url" alt="@Model.address" class="main-image">
                }
                else
                {
                    <div class="image-placeholder">
                        <i class="bi bi-house"></i>
                    </div>
                }
                <div class="image-counter">
                    <i class="bi bi-image"></i> Фото 1
                </div>
            </div>

            <!-- Информация -->
            <div class="property-info">
                <div class="property-header">
                    <h2 class="property-address">@Model.address</h2>
                    <div class="property-price">@Model.price.ToString("N0") ₽</div>
                    <div class="property-meta">
                        <div class="meta-item">
                            <i class="bi bi-tag"></i>
                            <span class="meta-label">Тип</span>
                            <span class="meta-value">@Model.property_type</span>
                        </div>
                        <div class="meta-item">
                            <i class="bi bi-rulers"></i>
                            <span class="meta-label">Площадь</span>
                            <span class="meta-value">@Model.area м²</span>
                        </div>
                        <div class="meta-item">
                            <i class="bi bi-door-open"></i>
                            <span class="meta-label">Комнат</span>
                            <span class="meta-value">@(Model.rooms?.ToString() ?? "-")</span>
                        </div>
                        <div class="property-status @(Model.is_available ? "status-available" : "status-sold")">
                            <i class="bi @(Model.is_available ? "bi-check-circle" : "bi-x-circle")"></i>
                            @(Model.is_available ? "Доступен" : "Продан")
                        </div>
                    </div>
                </div>

                <!-- Описание -->
                @if (!string.IsNullOrEmpty(Model.description))
                {
                    <div class="property-description">
                        <div class="description-title">
                            <i class="bi bi-text-paragraph"></i> Описание
                        </div>
                        <div class="description-text">@Model.description</div>
                    </div>
                }

                <!-- Характеристики -->
                <div class="property-specs">
                    <div class="spec-card">
                        <div class="spec-icon"><i class="bi bi-buildings"></i></div>
                        <div class="spec-title">Этаж</div>
                        <div class="spec-value">@(Model.floor?.ToString() ?? "-")</div>
                    </div>
                    <div class="spec-card">
                        <div class="spec-icon"><i class="bi bi-building"></i></div>
                        <div class="spec-title">Всего этажей</div>
                        <div class="spec-value">@(Model.total_floors?.ToString() ?? "-")</div>
                    </div>
                    @if (!string.IsNullOrEmpty(Model.main_image_url))
                    {
                        <div class="spec-card">
                            <div class="spec-icon"><i class="bi bi-image"></i></div>
                            <div class="spec-title">Фотографии</div>
                            <div class="spec-value">Есть</div>
                        </div>
                    }
                    <div class="spec-card">
                        <div class="spec-icon"><i class="bi bi-calendar"></i></div>
                        <div class="spec-title">Добавлен</div>
                        <div class="spec-value">Сегодня</div>
                    </div>
                </div>

                <!-- Кнопки действий -->
                <div class="action-buttons">
                    <!-- Для админов и риэлторов -->
                    @if (User.IsInRole("Admin") || User.IsInRole("Realtor"))
                    {
                        <a href="/Property/Edit/@Model.property_id" class="btn btn-primary">
                            <i class="bi bi-pencil-square"></i> Редактировать
                        </a>
                        <form action="/Property/Delete/@Model.property_id" method="post"
                              onsubmit="return confirm('Удалить этот объект?');" style="display:inline;">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-danger">
                                <i class="bi bi-trash"></i> Удалить
                            </button>
                        </form>
                    }

                    <!-- Для клиентов - кнопка резервирования -->
                    @if (User.IsInRole("Client") && Model.is_available)
                    {
                        <form action="/PropertyReservation/QuickReserve/@Model.property_id" method="post" style="display:inline;">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-primary" onclick="console.log('Отправка формы резервирования для объекта @Model.property_id');">
                                <i class="bi bi-calendar-check"></i> Зарезервировать
                            </button>
                        </form>
                    }

                    <a href="/Property" class="btn btn-secondary">
                        <i class="bi bi-list"></i> Все объекты
                    </a>
                </div>
            </div>
        </div>
    </div>

    <script>
        // Автоматическое скрытие уведомлений
        setTimeout(function() {
            var alerts = document.querySelectorAll('.alert');
            alerts.forEach(function(alert) {
                alert.style.opacity = '0';
                setTimeout(function() {
                    if (alert.parentNode) {
                        alert.parentNode.removeChild(alert);
                    }
                }, 300);
            });
        }, 5000);

    </script>
</body>
</html>