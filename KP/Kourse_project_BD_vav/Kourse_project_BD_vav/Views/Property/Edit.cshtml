@model Kourse_project_BD_vav.Models.Property
@{
    ViewData["Title"] = "Редактирование объекта";
}

<!DOCTYPE html>
<html>
<head>
    <title>@ViewData["Title"]</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #43e97b 0%, #38f9d7 100%);
            min-height: 100vh;
            padding: 20px;
        }

        .container {
            max-width: 1000px;
            margin: 0 auto;
        }

        /* Шапка */
        .header {
            background: white;
            padding: 20px 30px;
            border-radius: 15px;
            margin-bottom: 25px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            box-shadow: 0 4px 20px rgba(0,0,0,0.1);
            border-left: 5px solid #43e97b;
        }

            .header h1 {
                color: #2c3e50;
                font-size: 24px;
                display: flex;
                align-items: center;
                gap: 10px;
            }

        .back-btn {
            padding: 10px 20px;
            background: #f8f9fa;
            color: #495057;
            text-decoration: none;
            border-radius: 8px;
            font-weight: 600;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            transition: all 0.3s ease;
        }

            .back-btn:hover {
                background: #e9ecef;
                transform: translateX(-3px);
            }

        /* Форма */
        .form-container {
            background: white;
            border-radius: 15px;
            padding: 30px;
            box-shadow: 0 4px 30px rgba(0,0,0,0.1);
        }

        .form-title {
            font-size: 20px;
            color: #2c3e50;
            margin-bottom: 25px;
            padding-bottom: 15px;
            border-bottom: 2px solid #f8f9fa;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .form-title-id {
            background: #43e97b;
            color: white;
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 14px;
            font-weight: 600;
        }

        /* Сетка формы */
        .form-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 25px;
            margin-bottom: 30px;
        }

        /* Поля формы */
        .form-group {
            margin-bottom: 20px;
        }

        .form-label {
            display: block;
            margin-bottom: 8px;
            font-weight: 600;
            color: #2c3e50;
            font-size: 14px;
        }

            .form-label.required::after {
                content: " *";
                color: #e74c3c;
            }

        .form-control {
            width: 100%;
            padding: 12px 15px;
            border: 2px solid #e9ecef;
            border-radius: 8px;
            font-size: 15px;
            transition: all 0.3s ease;
            background: #f8f9fa;
        }

            .form-control:focus {
                outline: none;
                border-color: #43e97b;
                background: white;
                box-shadow: 0 0 0 3px rgba(67, 233, 123, 0.1);
            }

            .form-control::placeholder {
                color: #adb5bd;
            }

        .form-select {
            width: 100%;
            padding: 12px 15px;
            border: 2px solid #e9ecef;
            border-radius: 8px;
            font-size: 15px;
            background: #f8f9fa;
            color: #495057;
            cursor: pointer;
            transition: all 0.3s ease;
        }

            .form-select:focus {
                outline: none;
                border-color: #43e97b;
                background: white;
                box-shadow: 0 0 0 3px rgba(67, 233, 123, 0.1);
            }

        .form-textarea {
            min-height: 120px;
            resize: vertical;
        }

        /* Чекбокс */
        .form-check {
            display: flex;
            align-items: center;
            gap: 10px;
            margin: 20px 0;
            padding: 15px;
            background: #f8f9fa;
            border-radius: 8px;
        }

        .form-check-input {
            width: 20px;
            height: 20px;
            cursor: pointer;
            accent-color: #43e97b;
        }

        .form-check-label {
            font-weight: 500;
            color: #495057;
            cursor: pointer;
            flex: 1;
        }

        /* Ошибки */
        .validation-summary {
            background: #f8d7da;
            color: #721c24;
            padding: 15px 20px;
            border-radius: 8px;
            margin-bottom: 20px;
            border-left: 4px solid #e74c3c;
        }

        .field-validation-error {
            display: block;
            margin-top: 5px;
            color: #e74c3c;
            font-size: 13px;
            font-weight: 500;
        }

        /* Кнопки */
        .form-actions {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 15px;
            padding-top: 25px;
            border-top: 2px solid #f8f9fa;
        }

        .btn {
            padding: 12px 25px;
            border-radius: 10px;
            font-weight: 600;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 10px;
            border: none;
            cursor: pointer;
            transition: all 0.3s ease;
            font-size: 15px;
            min-width: 140px;
            justify-content: center;
        }

        .btn-primary {
            background: linear-gradient(135deg, #43e97b, #38f9d7);
            color: white;
        }

            .btn-primary:hover {
                transform: translateY(-3px);
                box-shadow: 0 6px 20px rgba(67, 233, 123, 0.4);
            }

        .btn-secondary {
            background: #f8f9fa;
            color: #495057;
            border: 2px solid #e9ecef;
        }

            .btn-secondary:hover {
                background: #e9ecef;
            }

        .btn-danger {
            background: linear-gradient(135deg, #e74c3c, #c0392b);
            color: white;
        }

            .btn-danger:hover {
                transform: translateY(-3px);
                box-shadow: 0 6px 20px rgba(231, 76, 60, 0.4);
            }

        /* Подсказки */
        .form-hint {
            display: block;
            margin-top: 5px;
            font-size: 12px;
            color: #6c757d;
            font-style: italic;
        }

        /* Информация о редактировании */
        .edit-info {
            background: #e3f2fd;
            color: #1976d2;
            padding: 12px 20px;
            border-radius: 8px;
            margin-bottom: 20px;
            border-left: 4px solid #2196f3;
            display: flex;
            align-items: center;
            gap: 10px;
            font-weight: 500;
        }

        /* Уведомления */
        .alert {
            padding: 15px 20px;
            border-radius: 10px;
            margin-bottom: 20px;
            font-weight: 500;
        }

        .alert-success {
            background: #d4edda;
            color: #155724;
            border: 1px solid #c3e6cb;
        }

        .alert-error {
            background: #f8d7da;
            color: #721c24;
            border: 1px solid #f5c6cb;
        }
    </style>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
</head>
<body>
    <div class="container">
        <!-- Уведомления -->
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success">
                <i class="bi bi-check-circle"></i> @TempData["SuccessMessage"]
            </div>
        }

        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-error">
                <i class="bi bi-exclamation-triangle"></i> @TempData["ErrorMessage"]
            </div>
        }

        <!-- Шапка -->
        <div class="header">
            <a href="/Property/Details/@Model.property_id" class="back-btn">
                <i class="bi bi-arrow-left"></i> Назад
            </a>
            <h1>
                <i class="bi bi-pencil-square"></i> Редактирование объекта
                <span class="form-title-id">ID: @Model.property_id</span>
            </h1>
        </div>

        <!-- Информация -->
        <div class="edit-info">
            <i class="bi bi-info-circle"></i>
            Редактирование объекта: @Model.address
        </div>

        <!-- Форма -->
        <form action="/Property/Edit" method="post" class="form-container">
            @Html.AntiForgeryToken()

            <input type="hidden" name="property_id" value="@Model.property_id" />

            <!-- Валидация -->
            @if (!ViewData.ModelState.IsValid)
            {
                <div class="validation-summary">
                    <i class="bi bi-exclamation-triangle"></i> Пожалуйста, исправьте ошибки в форме
                </div>
            }

            <div class="form-grid">
                <!-- Левая колонка -->
                <div>
                    <!-- Адрес -->
                    <div class="form-group">
                        <label class="form-label required">Адрес объекта</label>
                        <input type="text" name="address" class="form-control"
                               value="@Model.address"
                               placeholder="г. Москва, ул. Ленина, д. 5, кв. 12" required>
                        @Html.ValidationMessage("address", "", new { @class = "field-validation-error" })
                    </div>

                    <!-- Тип недвижимости -->
                    <div class="form-group">
                        <label class="form-label required">Тип недвижимости</label>
                        <select name="property_type" class="form-select" required>
                            <option value="">-- Выберите тип --</option>
                            <option value="Квартира" @(Model.property_type == "Квартира" ? "selected" : "")>Квартира</option>
                            <option value="Дом" @(Model.property_type == "Дом" ? "selected" : "")>Дом</option>
                            <option value="Офис" @(Model.property_type == "Офис" ? "selected" : "")>Офис</option>
                            <option value="Коммерческая" @(Model.property_type == "Коммерческая" ? "selected" : "")>Коммерческая</option>
                        </select>
                        @Html.ValidationMessage("property_type", "", new { @class = "field-validation-error" })
                    </div>

                    <!-- Площадь -->
                    <div class="form-group">
                        <label class="form-label required">Площадь (м²)</label>
                        <input type="number" name="area" class="form-control"
                               step="0.01" min="0.1"
                               value="@Model.area"
                               placeholder="75.5" required>
                        @Html.ValidationMessage("area", "", new { @class = "field-validation-error" })
                    </div>

                    <!-- Цена -->
                    <div class="form-group">
                        <label class="form-label required">Цена (руб.)</label>
                        <input type="number" name="price" class="form-control"
                               min="1"
                               value="@Model.price"
                               placeholder="15000000" required>
                        @Html.ValidationMessage("price", "", new { @class = "field-validation-error" })
                        <span class="form-hint">Введите цену в рублях без пробелов</span>
                    </div>
                </div>

                <!-- Правая колонка -->
                <div>
                    <!-- Количество комнат -->
                    <div class="form-group">
                        <label class="form-label">Количество комнат</label>
                        <input type="number" name="rooms" class="form-control"
                               min="0" max="50"
                               value="@Model.rooms"
                               placeholder="3">
                    </div>

                    <!-- Этаж -->
                    <div class="form-group">
                        <label class="form-label">Этаж</label>
                        <input type="number" name="floor" class="form-control"
                               min="0" max="200"
                               value="@Model.floor"
                               placeholder="5">
                    </div>

                    <!-- Всего этажей -->
                    <div class="form-group">
                        <label class="form-label">Всего этажей</label>
                        <input type="number" name="total_floors" class="form-control"
                               min="1" max="200"
                               value="@Model.total_floors"
                               placeholder="12">
                    </div>

                    <!-- URL основного фото -->
                    <div class="form-group">
                        <label class="form-label">URL основного фото</label>
                        <input type="text" name="main_image_url" class="form-control"
                               value="@Model.main_image_url"
                               placeholder="https://example.com/photo.jpg">
                        <span class="form-hint">Введите полную ссылку на изображение</span>
                    </div>
                </div>
            </div>

            <!-- Описание -->
            <div class="form-group">
                <label class="form-label">Описание</label>
                <textarea name="description" class="form-control form-textarea"
                          placeholder="Опишите объект...">@Model.description</textarea>
                <span class="form-hint">Максимально подробно опишите объект</span>
            </div>

            <!-- Дополнительные фото -->
            <div class="form-group">
                <label class="form-label">Дополнительные фото (JSON)</label>
                <textarea name="image_urls" class="form-control form-textarea"
                          placeholder='["https://example.com/photo1.jpg", "https://example.com/photo2.jpg"]'>@Model.image_urls</textarea>
                <span class="form-hint">Введите JSON массив URL через запятую</span>
            </div>

            <!-- Статус -->
            <div class="form-check">
                <input type="checkbox" name="is_available" value="true"
                       class="form-check-input" id="is_available" @(Model.is_available ? "checked" : "")>
                <label class="form-check-label" for="is_available">
                    Объект доступен для просмотра
                </label>
            </div>

            <!-- Кнопки -->
            <div class="form-actions">
                <a href="/Property/Details/@Model.property_id" class="btn btn-secondary">
                    <i class="bi bi-eye"></i> Просмотр
                </a>
                <a href="/Property" class="btn btn-secondary">
                    <i class="bi bi-list"></i> Все объекты
                </a>
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-check-circle"></i> Сохранить изменения
                </button>
            </div>
        </form>
    </div>

    <script>
        // Автоматическое скрытие уведомлений
        setTimeout(() => {
            document.querySelectorAll('.alert').forEach(alert => {
                alert.style.opacity = '0';
                setTimeout(() => alert.remove(), 300);
            });
        }, 5000);

        // Предупреждение при уходе с несохраненной формы
        let formChanged = false;
        const form = document.querySelector('form');

        form.addEventListener('input', () => {
            formChanged = true;
        });

        window.addEventListener('beforeunload', (e) => {
            if (formChanged) {
                e.preventDefault();
                e.returnValue = '';
            }
        });

        document.querySelectorAll('a').forEach(link => {
            link.addEventListener('click', (e) => {
                if (formChanged && !confirm('У вас есть несохраненные изменения. Продолжить?')) {
                    e.preventDefault();
                }
            });
        });
    </script>
</body>
</html>