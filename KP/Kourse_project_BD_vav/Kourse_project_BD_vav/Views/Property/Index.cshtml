@model List<Kourse_project_BD_vav.Models.Property>
@{
    ViewData["Title"] = "Объекты недвижимости";
}

<!DOCTYPE html>
<html>
<head>
    <title>@ViewData["Title"]</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #e0e0e0 0%, #bdbdbd 100%);
            min-height: 100vh;
            padding: 20px;
        }

        .container {
            max-width: 1200px;
            margin: 0 auto;
        }

        /* Шапка */
        .header {
            background: white;
            padding: 20px 30px;
            border-radius: 15px;
            margin-bottom: 25px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            box-shadow: 0 4px 20px rgba(0,0,0,0.1);
            border-left: 5px solid #6c757d;
            animation: slideDown 0.5s ease;
        }

        @@keyframes slideDown {
            from {
                opacity: 0;
                transform: translateY(-20px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .back-btn {
            padding: 10px 20px;
            background: #f8f9fa;
            color: #495057;
            text-decoration: none;
            border-radius: 8px;
            font-weight: 600;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            transition: all 0.3s ease;
        }

        .back-btn:hover {
            background: #e9ecef;
            transform: translateX(-3px);
            box-shadow: 0 2px 8px rgba(0,0,0,0.1);
        }

        /* Уведомления */
        .alert {
            padding: 15px 20px;
            border-radius: 10px;
            margin-bottom: 20px;
            font-weight: 500;
            animation: slideDown 0.5s ease;
        }

        .alert-success {
            background: #d4edda;
            color: #155724;
            border: 1px solid #c3e6cb;
        }

        .alert-error {
            background: #f8d7da;
            color: #721c24;
            border: 1px solid #f5c6cb;
        }

        /* Карточки объектов */
        .properties-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
            gap: 25px;
            margin-bottom: 40px;
            align-items: start;
        }

        .property-card {
            background: white;
            border-radius: 15px;
            overflow: hidden;
            box-shadow: 0 4px 15px rgba(0,0,0,0.08);
            transition: all 0.3s ease;
            position: relative;
        }

        .property-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 8px 25px rgba(0,0,0,0.15);
        }

        .property-image {
            height: 200px;
            width: 100%;
            background: linear-gradient(135deg, #6c757d, #495057);
            position: relative;
            overflow: hidden;
        }

        .property-image img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .property-type {
            position: absolute;
            top: 15px;
            right: 15px;
            background: rgba(255,255,255,0.9);
            padding: 6px 15px;
            border-radius: 20px;
            font-weight: 600;
            font-size: 12px;
            color: #2c3e50;
        }

        .property-content {
            padding: 20px;
        }

        .property-address {
            font-size: 18px;
            font-weight: 600;
            color: #2c3e50;
            margin-bottom: 10px;
            line-height: 1.3;
        }

        .property-price {
            font-size: 24px;
            font-weight: 700;
            color: #6c757d;
            margin-bottom: 15px;
        }

        .property-details {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 10px;
            margin-bottom: 20px;
        }

        .detail-item {
            text-align: center;
            padding: 8px;
            background: #f8f9fa;
            border-radius: 8px;
        }

        .detail-label {
            font-size: 11px;
            color: #6c757d;
            text-transform: uppercase;
            margin-bottom: 3px;
        }

        .detail-value {
            font-size: 14px;
            font-weight: 600;
            color: #2c3e50;
        }

        .property-status {
            display: inline-block;
            padding: 6px 15px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 600;
            margin-bottom: 15px;
        }

        .status-available {
            background: #d4edda;
            color: #155724;
        }

        .status-sold {
            background: #f8d7da;
            color: #721c24;
        }

        /* Кнопки действий */
        .property-actions {
            display: flex;
            gap: 10px;
            margin-top: 15px;
            align-items: center;
            flex-wrap: wrap;
        }

        .property-actions > * {
            flex: 0 0 auto;
        }

        .property-actions .delete-form {
            display: inline-flex;
            margin: 0;
            padding: 0;
            border: none;
            background: none;
            align-items: center;
            vertical-align: middle;
        }

        .property-actions .delete-form button {
            margin: 0;
            white-space: nowrap;
        }

        .btn {
            padding: 10px 20px;
            border-radius: 8px;
            font-weight: 600;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            border: none;
            cursor: pointer;
            transition: all 0.3s ease;
            font-size: 14px;
            box-sizing: border-box;
        }

        .btn-primary {
            background: linear-gradient(135deg, #6c757d, #495057);
            color: white;
        }

        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(108, 117, 125, 0.4);
        }

        .btn-secondary {
            background: #f8f9fa;
            color: #495057;
            border: 1px solid #ddd;
        }

        .btn-secondary:hover {
            background: #e9ecef;
        }

        .btn-danger {
            background: linear-gradient(135deg, #6c757d, #495057);
            color: white;
        }

        .btn-danger:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(108, 117, 125, 0.3);
        }

        /* Пустое состояние */
        .empty-state {
            background: white;
            padding: 60px 40px;
            text-align: center;
            border-radius: 15px;
            margin: 40px 0;
            box-shadow: 0 4px 20px rgba(0,0,0,0.1);
            animation: slideDown 0.8s ease;
        }

        .empty-icon {
            font-size: 64px;
            margin-bottom: 20px;
            opacity: 0.5;
        }

        .empty-title {
            color: #6c757d;
            margin-bottom: 15px;
            font-size: 24px;
        }

        .empty-text {
            color: #6c757d;
            max-width: 500px;
            margin: 0 auto 25px;
            line-height: 1.6;
        }
    </style>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
</head>
<body>
    <div class="container">
        <!-- Шапка -->
        <div class="header">
            <h1 style="margin: 0; color: #343a40; display: flex; align-items: center; gap: 10px;">
                <i class="bi bi-houses"></i> Объекты недвижимости
            </h1>
            <div style="display: flex; gap: 10px;">
                <a href="/Home/Dashboard" class="back-btn">
                    <i class="bi bi-arrow-left"></i> Назад
                </a>
                @if (User.IsInRole("Admin") || User.IsInRole("Realtor"))
                {
                    <a href="/Property/Create" class="btn btn-primary">
                        <i class="bi bi-plus-circle"></i> Добавить объект
                    </a>
                }
            </div>
        </div>

        <!-- Уведомления -->
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success">
                <i class="bi bi-check-circle"></i> @TempData["SuccessMessage"]
            </div>
        }

        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-error">
                <i class="bi bi-exclamation-triangle"></i> @TempData["ErrorMessage"]
            </div>
        }

        <!-- Список объектов -->
        @if (Model != null && Model.Any())
        {
            <div class="properties-grid">
                @foreach (var property in Model)
                {
                    <div class="property-card">
                        <div class="property-image">
                            @if (!string.IsNullOrEmpty(property.main_image_url))
                            {
                                <img src="@property.main_image_url" alt="@property.address">
                            }
                            else
                            {
                                <div style="display: flex; align-items: center; justify-content: center; height: 100%; color: white; font-size: 48px;">
                                    <i class="bi bi-house"></i>
                                </div>
                            }
                            <div class="property-type">@property.property_type</div>
                        </div>

                        <div class="property-content">
                            <h3 class="property-address">@property.address</h3>
                            <div class="property-price">@property.price.ToString("N0") ₽</div>

                            <div class="property-details">
                                <div class="detail-item">
                                    <div class="detail-label">Площадь</div>
                                    <div class="detail-value">@property.area м²</div>
                                </div>
                                <div class="detail-item">
                                    <div class="detail-label">Комнат</div>
                                    <div class="detail-value">@(property.rooms?.ToString() ?? "-")</div>
                                </div>
                                <div class="detail-item">
                                    <div class="detail-label">Этаж</div>
                                    <div class="detail-value">@(property.floor?.ToString() ?? "-")</div>
                                </div>
                            </div>

                            <div class="property-status @(property.is_available ? "status-available" : "status-sold")">
                                @(property.is_available ? "Доступен" : "Продан")
                            </div>

                            <div class="property-actions">
                                <a href="/Property/Details/@property.property_id" class="btn btn-secondary">
                                    <i class="bi bi-eye"></i> Просмотр
                                </a>

                                @if (User.IsInRole("Admin") || User.IsInRole("Realtor"))
                                {
                                    <a href="/Property/Edit/@property.property_id" class="btn btn-primary">
                                        <i class="bi bi-pencil"></i> Редактировать
                                    </a>
                                    <form action="/Property/Delete/@property.property_id" method="post"
                                          onsubmit="return confirm('Удалить объект @property.address?');" 
                                          class="delete-form">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-danger">
                                            <i class="bi bi-trash"></i> Удалить
                                        </button>
                                    </form>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="empty-state">
                <div class="empty-icon">
                    <i class="bi bi-house-x"></i>
                </div>
                <h3 class="empty-title">Нет объектов недвижимости</h3>
                <p class="empty-text">Добавьте первый объект, чтобы начать работу</p>
                @if (User.IsInRole("Admin") || User.IsInRole("Realtor"))
                {
                    <a href="/Property/Create" class="btn btn-primary" style="margin-top: 20px;">
                        <i class="bi bi-plus-circle"></i> Добавить объект
                    </a>
                }
            </div>
        }
    </div>

    <script>
        // Автоматическое скрытие уведомлений через 5 секунд
        setTimeout(function() {
            var alerts = document.querySelectorAll('.alert');
            alerts.forEach(function(alert) {
                alert.style.opacity = '0';
                setTimeout(function() {
                    if (alert.parentNode) {
                        alert.parentNode.removeChild(alert);
                    }
                }, 300);
            });
        }, 5000);
    </script>
</body>
</html>
