@model Kourse_project_BD_vav.Interfaces.SyncStatus
@inject Microsoft.EntityFrameworkCore.DbContextOptions<Kourse_project_BD_vav.Data.PgDbContext> DbContextOptions
@using Microsoft.EntityFrameworkCore
@{
    ViewData["Title"] = "Панель управления";
    var userRole = ViewBag.UserRole as string;
    var userName = ViewBag.UserName as string;

    // Для клиента получаем количество доступных объектов
    var availablePropertiesCount = 0;
    if (userRole == "Client")
    {
        try
        {
            using (var context = new Kourse_project_BD_vav.Data.PgDbContext(DbContextOptions))
            {
                availablePropertiesCount = await context.Properties.CountAsync(p => p.is_available);
            }
        }
        catch
        {
            availablePropertiesCount = 0;
        }
    }

    // Для риэлтора получаем количество доступных объектов
    var availablePropertiesCountForRealtor = 0;
    if (userRole == "Realtor")
    {
        try
        {
            using (var context = new Kourse_project_BD_vav.Data.PgDbContext(DbContextOptions))
            {
                availablePropertiesCountForRealtor = await context.Properties.CountAsync(p => p.is_available);
            }
        }
        catch
        {
            availablePropertiesCountForRealtor = 0;
        }
    }
}

<!DOCTYPE html>
<html>
<head>
    <title>@ViewData["Title"]</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            margin: 0;
            padding: 0;
            background: linear-gradient(135deg, #e0e0e0 0%, #bdbdbd 100%);
            min-height: 100vh;
            padding: 20px;
        }

        .dashboard-container {
            max-width: 1200px;
            margin: 0 auto;
        }

        @@keyframes slideDown {
            from {
                opacity: 0;
                transform: translateY(-20px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .header {
            background: white;
            padding: 20px 30px;
            border-radius: 15px;
            margin-bottom: 25px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            box-shadow: 0 4px 20px rgba(0,0,0,0.1);
            border-left: 5px solid #6c757d;
            animation: slideDown 0.5s ease;
        }

        .user-info {
            text-align: right;
        }

        .role-badge {
            display: inline-block;
            padding: 6px 18px;
            background: linear-gradient(135deg, #6c757d, #495057);
            color: white;
            border-radius: 20px;
            font-size: 14px;
            font-weight: 500;
            letter-spacing: 0.5px;
            margin-top: 5px;
        }

        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 20px;
            margin-bottom: 30px;
        }

        .stat-card {
            background: white;
            padding: 25px;
            border-radius: 15px;
            box-shadow: 0 4px 20px rgba(0,0,0,0.1);
            text-align: center;
            transition: all 0.3s ease;
            animation: slideDown 0.6s ease;
        }

            .stat-card:hover {
                transform: translateY(-5px);
                box-shadow: 0 8px 25px rgba(0,0,0,0.2);
            }

        .stat-value {
            font-size: 36px;
            font-weight: bold;
            color: #343a40;
            margin: 10px 0;
        }

        .stat-label {
            color: #6c757d;
            font-size: 14px;
            text-transform: uppercase;
            letter-spacing: 1px;
            opacity: 0.9;
        }

        .sync-status {
            background: white;
            padding: 25px;
            border-radius: 15px;
            box-shadow: 0 4px 30px rgba(0,0,0,0.1);
            margin-bottom: 30px;
            animation: slideDown 0.7s ease;
        }

        .sync-table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 20px;
        }

            .sync-table th, .sync-table td {
                padding: 15px;
                text-align: left;
                border-bottom: 1px solid #e9ecef;
            }

            .sync-table th {
                background: #343a40;
                color: white;
                font-weight: 600;
                text-transform: uppercase;
                font-size: 12px;
                letter-spacing: 1px;
            }

            .sync-table tbody tr:hover {
                background: #f8f9fa;
            }

        .status-badge {
            padding: 5px 12px;
            border-radius: 12px;
            font-size: 12px;
            font-weight: 500;
            display: inline-block;
        }

        .status-synced {
            background: #d4edda;
            color: #155724;
        }

        .status-outofsync {
            background: #f8d7da;
            color: #721c24;
        }

        .status-pending {
            background: #fff3cd;
            color: #856404;
        }

        .nav-menu {
            display: flex;
            gap: 10px;
            margin-bottom: 25px;
            flex-wrap: wrap;
        }

        .nav-btn {
            padding: 12px 25px;
            background: linear-gradient(135deg, #6c757d, #495057);
            color: white;
            border: none;
            border-radius: 10px;
            cursor: pointer;
            text-decoration: none;
            font-weight: 600;
            transition: all 0.3s ease;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            font-size: 15px;
        }

            .nav-btn:hover {
                transform: translateY(-3px);
                box-shadow: 0 6px 20px rgba(108, 117, 125, 0.4);
            }

        .action-btn {
            display: inline-block;
            padding: 12px 25px;
            background: linear-gradient(135deg, #6c757d, #495057);
            color: white;
            text-decoration: none;
            border-radius: 10px;
            margin-top: 20px;
            font-weight: 600;
            transition: all 0.3s ease;
            border: none;
            cursor: pointer;
        }

            .action-btn:hover {
                transform: translateY(-3px);
                box-shadow: 0 6px 20px rgba(108, 117, 125, 0.4);
                color: white;
            }

        .deal-info {
            margin: 10px 0;
        }

        .deal-info-row {
            display: flex;
            align-items: center;
            margin: 5px 0;
        }

        .deal-info-label {
            min-width: 100px;
            font-weight: 600;
            color: #495057;
        }

        .deal-info-value {
            color: #6c757d;
        }

        .empty-state {
            text-align: center;
            padding: 40px 20px;
            color: #6c757d;
        }

        .empty-state-icon {
            font-size: 64px;
            margin-bottom: 20px;
            opacity: 0.5;
        }

        .property-link {
            color: #3498db;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 5px;
        }

            .property-link:hover {
                text-decoration: underline;
            }

        .client-deal-section {
            background: #f8f9fa;
            padding: 20px;
            border-radius: 10px;
            margin: 15px 0;
            border-left: 4px solid #6c757d;
        }

        .quick-actions {
            display: flex;
            gap: 10px;
            margin-top: 20px;
            flex-wrap: wrap;
        }

        .btn-green {
            background: linear-gradient(135deg, #6c757d, #495057);
            color: white;
        }

            .btn-green:hover {
                transform: translateY(-3px);
                box-shadow: 0 6px 20px rgba(108, 117, 125, 0.4);
            }

        .btn-blue {
            background: linear-gradient(135deg, #6c757d, #495057);
            color: white;
        }

        .btn-blue:hover {
            transform: translateY(-3px);
            box-shadow: 0 6px 20px rgba(108, 117, 125, 0.4);
        }

        /* Модальное окно */
        .modal {
            display: none;
            position: fixed;
            z-index: 1000;
            left: 0;
            top: 0;
            width: 100%;
            height: 100%;
            overflow: auto;
            background-color: rgba(0,0,0,0.5);
        }

        .modal-content {
            background-color: #fefefe;
            margin: 15% auto;
            padding: 20px;
            border: 1px solid #888;
            width: 500px;
            border-radius: 10px;
            box-shadow: 0 4px 20px rgba(0,0,0,0.3);
            animation: modalFadeIn 0.3s;
        }

        @@keyframes modalFadeIn {
            from {
                opacity: 0;
                transform: translateY(-50px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .close {
            color: #aaa;
            font-size: 28px;
            font-weight: bold;
            cursor: pointer;
            transition: color 0.3s;
        }

        .close:hover {
            color: #000;
        }
    </style>
</head>
<body>
    <div class="dashboard-container">
        <!-- Шапка -->
        <div class="header">
            <div>
                <h1>Панель управления</h1>
                <p>Добро пожаловать в систему управления недвижимостью</p>
            </div>
            <div class="user-info">
                <div><strong>@userName</strong></div>
                <div class="role-badge">@userRole</div>
                <div style="margin-top: 10px; display: flex; gap: 10px;">
                    <a href="/Account/Profile" class="nav-btn">Профиль</a>
                    <a href="/Account/Logout" class="nav-btn" style="background: linear-gradient(135deg, #6c757d, #495057); color: white;">Выйти</a>
                </div>
            </div>
        </div>

        <!-- Навигация -->
        <div class="nav-menu">
            @if (userRole == "Admin" || userRole == "Realtor")
            {
                <a href="/Home/Dashboard" class="nav-btn">Дашборд</a>
            }

            @if (userRole == "Admin")
            {
                <a href="/Client/Index" class="nav-btn">Клиенты</a>
                <a href="/Realtor/Index" class="nav-btn">Риэлторы</a>
                <a href="/Property/Index" class="nav-btn">Недвижимость</a>
                <a href="/Deal/Index" class="nav-btn">Сделки</a>
            }

            @if (userRole == "Realtor")
            {
                <a href="/Client/Index" class="nav-btn">Клиенты</a>
                <a href="/Property/Index" class="nav-btn">Недвижимость</a>
                <a href="/Deal/Index" class="nav-btn">Сделки</a>
                <a href="/PropertyReservation" class="nav-btn">Заявки на резервирование</a>
            }

            @if (userRole == "Admin")
            {
                <a href="/Home/Sync" class="nav-btn" style="background: linear-gradient(135deg, #27ae60, #219653);">Синхронизация</a>
                <button type="button" class="nav-btn" onclick="exportDeals()" style="background: linear-gradient(135deg, #27ae60, #219653); color: white; border: none; cursor: pointer;">Экспорт</button>
                <button type="button" class="nav-btn" onclick="showImportModal()" style="background: linear-gradient(135deg, #3498db, #2980b9); color: white; border: none; cursor: pointer;">Импорт</button>
            }

            @if (userRole == "Client")
            {
                <a href="/Property/Index" class="nav-btn">Найти недвижимость</a>
                <a href="/Deal/MyDeals" class="nav-btn">Мои сделки</a>
            }
        </div>

        <!-- Модальное окно для импорта -->
        @if (userRole == "Admin")
        {
            <div id="importModal" class="modal" style="display: none; position: fixed; z-index: 1000; left: 0; top: 0; width: 100%; height: 100%; overflow: auto; background-color: rgba(0,0,0,0.5);">
                <div class="modal-content" style="background-color: #fefefe; margin: 15% auto; padding: 20px; border: 1px solid #888; width: 500px; border-radius: 10px; box-shadow: 0 4px 20px rgba(0,0,0,0.3);">
                    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
                        <h2 style="margin: 0; color: #2c3e50;">Импорт Deals из JSON</h2>
                        <span class="close" onclick="closeImportModal()" style="color: #aaa; font-size: 28px; font-weight: bold; cursor: pointer;">&times;</span>
                    </div>
                    <form id="importForm" enctype="multipart/form-data">
                        @Html.AntiForgeryToken()
                        <div style="margin-bottom: 20px;">
                            <label for="importFile" style="display: block; margin-bottom: 10px; font-weight: 600; color: #2c3e50;">Выберите JSON файл:</label>
                            <input type="file" id="importFile" name="file" accept=".json" required style="width: 100%; padding: 10px; border: 2px solid #ddd; border-radius: 5px; font-size: 14px;">
                            <div style="margin-top: 10px; padding: 10px; background-color: #fff3cd; border-left: 4px solid #ffc107; color: #856404; font-size: 13px;">
                                <strong>Внимание:</strong> Все существующие данные в таблице Deals будут заменены!
                            </div>
                        </div>
                        <div id="importError" style="display: none; padding: 10px; margin-bottom: 15px; background-color: #f8d7da; color: #721c24; border-radius: 5px; border-left: 4px solid #dc3545;"></div>
                        <div id="importSuccess" style="display: none; padding: 10px; margin-bottom: 15px; background-color: #d4edda; color: #155724; border-radius: 5px; border-left: 4px solid #28a745;"></div>
                        <div style="display: flex; gap: 10px; justify-content: flex-end;">
                            <button type="button" onclick="closeImportModal()" style="padding: 10px 20px; background: #6c757d; color: white; border: none; border-radius: 5px; cursor: pointer; font-weight: 600;">Отмена</button>
                            <button type="submit" style="padding: 10px 20px; background: #007bff; color: white; border: none; border-radius: 5px; cursor: pointer; font-weight: 600;">Импортировать</button>
                        </div>
                    </form>
                </div>
            </div>
        }

        <!-- Статистика -->
        <div class="stats-grid">
            @if (userRole == "Admin")
            {
                var stats = ViewBag.Stats as dynamic;
                <div class="stat-card">
                    <div class="stat-label">Клиентов</div>
                    <div class="stat-value">@(stats?.TotalClients ?? 0)</div>
                </div>
                <div class="stat-card">
                    <div class="stat-label">Риэлторов</div>
                    <div class="stat-value">@(stats?.TotalRealtors ?? 0)</div>
                </div>
                <div class="stat-card">
                    <div class="stat-label">Объектов</div>
                    <div class="stat-value">@(stats?.TotalProperties ?? 0)</div>
                </div>
                <div class="stat-card">
                    <div class="stat-label">Активных сделок</div>
                    <div class="stat-value">@(stats?.ActiveDeals ?? 0)</div>
                </div>
            }
            else if (userRole == "Realtor")
            {
                var stats = ViewBag.Stats as dynamic;
                <div class="stat-card">
                    <div class="stat-label">Мои объекты</div>
                    <div class="stat-value">@(stats?.MyProperties ?? 0)</div>
                </div>
                <div class="stat-card">
                    <div class="stat-label">Мои сделки</div>
                    <div class="stat-value">@(stats?.MyDeals ?? 0)</div>
                </div>
                <div class="stat-card">
                    <div class="stat-label">Доступных объектов</div>
                    <div class="stat-value">@availablePropertiesCountForRealtor</div>
                </div>
            }
            else if (userRole == "Client")
            {
                var stats = ViewBag.Stats as dynamic;
                <div class="stat-card">
                    <div class="stat-label">Мои сделки</div>
                    <div class="stat-value">@(stats?.MyDeals ?? 0)</div>
                </div>
                <div class="stat-card">
                    <div class="stat-label">Всего потрачено</div>
                    <div class="stat-value">@((stats?.TotalSpent ?? 0).ToString("C"))</div>
                </div>
                <div class="stat-card">
                    <div class="stat-label">Активных сделок</div>
                    <div class="stat-value">@(stats?.ActiveDeals ?? 0)</div>
                </div>
                <div class="stat-card">
                    <div class="stat-label">Доступных объектов</div>
                    <div class="stat-value">@availablePropertiesCount</div>
                </div>
            }
        </div>

        <!-- Синхронизация (только для админа) -->
        @if (userRole == "Admin")
        {
            <div class="sync-status">
                <h2 style="color: #343a40; margin-bottom: 20px; display: flex; align-items: center; gap: 10px;">Статус синхронизации БД</h2>

                <table class="sync-table">
                    <thead>
                        <tr>
                            <th>Таблица</th>
                            <th>PostgreSQL (Основная)</th>
                            <th>MSSQL (Standby)</th>
                            <th>Статус</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model?.Tables != null && Model.Tables.Count > 0)
                        {
                            @foreach (var table in Model.Tables)
                            {
                                <tr>
                                    <td>@table.Name</td>
                                    <td>@table.PgCount записей</td>
                                    <td>@table.MssqlCount записей</td>
                                    <td>
                                        <span class="status-badge @(table.IsSynced ? "status-synced" : "status-outofsync")">
                                            @(table.IsSynced ? "Синхронизировано" : "Требует синхронизации")
                                        </span>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="4" style="text-align: center; padding: 20px; color: #7f8c8d;">
                                    Данные о синхронизации загружаются...
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>

                <form asp-action="PerformSync" asp-controller="Home" method="post">
                    <button type="submit" class="action-btn" style="background: linear-gradient(135deg, #27ae60, #219653);">Запустить синхронизацию</button>
                </form>
            </div>
        }

        <!-- Профиль риэлтора -->
        @if (userRole == "Realtor" && ViewBag.Realtor != null)
        {
            var realtor = ViewBag.Realtor as Kourse_project_BD_vav.Models.Realtor;
            <div class="sync-status">
                <h2 style="color: #343a40; margin-bottom: 20px; display: flex; align-items: center; gap: 10px;">Мой профиль риэлтора</h2>
                <div class="deal-info">
                    <div class="deal-info-row">
                        <span class="deal-info-label">Имя:</span>
                        <span class="deal-info-value">@realtor.full_name</span>
                    </div>
                    <div class="deal-info-row">
                        <span class="deal-info-label">Телефон:</span>
                        <span class="deal-info-value">@realtor.phone_number</span>
                    </div>
                    <div class="deal-info-row">
                        <span class="deal-info-label">Email:</span>
                        <span class="deal-info-value">@realtor.email</span>
                    </div>
                    <div class="deal-info-row">
                        <span class="deal-info-label">Ставка комиссии:</span>
                        <span class="deal-info-value">@realtor.commission_rate%</span>
                    </div>
                    <div class="deal-info-row">
                        <span class="deal-info-label">Дата найма:</span>
                        <span class="deal-info-value">@realtor.hire_date.ToString("dd.MM.yyyy")</span>
                    </div>
                </div>

                <div class="quick-actions">
                    <a href="/Property/Create" class="nav-btn">Добавить объект</a>
                    <a href="/Deal/Create" class="nav-btn">Создать сделку</a>
                </div>
            </div>
        }

        <!-- Профиль клиента -->
        @if (userRole == "Client" && ViewBag.Client != null)
        {
            var client = ViewBag.Client as Kourse_project_BD_vav.Models.Client;
            <div class="sync-status">
                <h2 style="color: #343a40; margin-bottom: 20px; display: flex; align-items: center; gap: 10px;">Мой профиль клиента</h2>
                <div class="deal-info">
                    <div class="deal-info-row">
                        <span class="deal-info-label">Имя:</span>
                        <span class="deal-info-value">@client.full_name</span>
                    </div>
                    <div class="deal-info-row">
                        <span class="deal-info-label">Телефон:</span>
                        <span class="deal-info-value">@client.phone_number</span>
                    </div>
                    <div class="deal-info-row">
                        <span class="deal-info-label">Email:</span>
                        <span class="deal-info-value">@client.email</span>
                    </div>
                    @if (!string.IsNullOrEmpty(client.passport_number))
                    {
                        <div class="deal-info-row">
                            <span class="deal-info-label">Паспорт:</span>
                            <span class="deal-info-value">@client.passport_number</span>
                        </div>
                    }
                    <div class="deal-info-row">
                        <span class="deal-info-label">Дата регистрации:</span>
                        <span class="deal-info-value">@client.registration_date.ToString("dd.MM.yyyy")</span>
                    </div>
                </div>
            </div>
        }

        <!-- Сделки клиента -->
        @if (userRole == "Client" && ViewBag.MyDeals != null)
        {
            var deals = ViewBag.MyDeals as List<Kourse_project_BD_vav.Models.Deal>;
            if (deals != null && deals.Any())
            {
                <div class="sync-status">
                    <h2 style="color: #343a40; margin-bottom: 20px; display: flex; align-items: center; gap: 10px;">Мои последние сделки</h2>
                    @foreach (var deal in deals)
                    {
                        <div class="client-deal-section">
                            <div class="deal-info">
                                <div class="deal-info-row">
                                    <span class="deal-info-label">ID сделки:</span>
                                    <span class="deal-info-value">#@deal.deal_id</span>
                                </div>
                                <div class="deal-info-row">
                                    <span class="deal-info-label">Тип:</span>
                                    <span class="deal-info-value">@deal.deal_type</span>
                                </div>
                                <div class="deal-info-row">
                                    <span class="deal-info-label">Дата:</span>
                                    <span class="deal-info-value">@deal.deal_date.ToString("dd.MM.yyyy")</span>
                                </div>
                                <div class="deal-info-row">
                                    <span class="deal-info-label">Цена:</span>
                                    <span class="deal-info-value">@deal.deal_price.ToString("C")</span>
                                </div>
                                <div class="deal-info-row">
                                    <span class="deal-info-label">Статус:</span>
                                    <span class="status-badge @(deal.deal_status == "Завершена" ? "status-synced" :
                                                                                                     deal.deal_status == "В обработке" ? "status-pending" : "status-outofsync")">
                            @deal.deal_status
                        </span>
                    </div>
                    @if (deal.property != null)
                                {
                                    <div class="deal-info-row">
                                        <span class="deal-info-label">Объект:</span>
                                        <a href="/Property/Details/@deal.property_id" class="property-link">
                                            @deal.property.address
                                        </a>
                                    </div>
                                }
                                @if (deal.realtor != null)
                                {
                                    <div class="deal-info-row">
                                        <span class="deal-info-label">Риэлтор:</span>
                                        <span class="deal-info-value">@deal.realtor.full_name</span>
                                    </div>
                                }
                            </div>
                        </div>
                    }

                    <div class="quick-actions">
                        <a href="/Deal/MyDeals" class="action-btn">Все мои сделки</a>
                        <a href="/Property/Index" class="nav-btn">Найти недвижимость</a>
                    </div>
                </div>
            }
            else
            {
                <div class="sync-status">
                    <div class="empty-state">
                        <div class="empty-state-icon" style="font-size: 64px; margin-bottom: 20px; opacity: 0.5; color: #6c757d;">📄</div>
                        <h3 style="color: #6c757d; margin-bottom: 15px; font-size: 24px;">У вас пока нет сделок</h3>
                        <p style="color: #6c757d; max-width: 500px; margin: 0 auto 25px; line-height: 1.6;">Сделки появятся после оформления договора с риэлтором</p>
                        <div class="quick-actions" style="justify-content: center;">
                            <a href="/Property/Index" class="action-btn">Найти недвижимость</a>
                        </div>
                    </div>
                </div>
            }
        }
    </div>

    <script>
        // Анимация при загрузке
        document.addEventListener('DOMContentLoaded', function() {
            // Анимация карточек статистики
            const statCards = document.querySelectorAll('.stat-card');
            statCards.forEach((card, index) => {
                card.style.opacity = '0';
                card.style.transform = 'translateY(20px)';

                setTimeout(() => {
                    card.style.transition = 'all 0.5s ease';
                    card.style.opacity = '1';
                    card.style.transform = 'translateY(0)';
                }, index * 100);
            });

            // Подсветка активной навигационной кнопки
            const currentPath = window.location.pathname;
            const navButtons = document.querySelectorAll('.nav-btn');

            navButtons.forEach(btn => {
                if (btn.getAttribute('href') === currentPath) {
                    btn.style.background = '#2c3e50';
                    btn.style.color = 'white';
                }
            });
        });

        // Экспорт Deals
        function exportDeals() {
            console.log('[EXPORT] Начало экспорта Deals...');
            try {
                const link = document.createElement('a');
                link.href = '/Home/ExportDeals';
                link.download = 'deals_export_' + new Date().toISOString().replace(/[:.]/g, '-').slice(0, -5) + '.json';
                document.body.appendChild(link);
                link.click();
                document.body.removeChild(link);
                console.log('[EXPORT] Экспорт успешно инициирован');
            } catch (error) {
                console.error('[EXPORT ERROR]', error);
                alert('Ошибка при экспорте: ' + error.message);
            }
        }

        // Показать модальное окно импорта
        function showImportModal() {
            console.log('[IMPORT] Открытие модального окна импорта...');
            const modal = document.getElementById('importModal');
            if (modal) {
                modal.style.display = 'block';
                document.getElementById('importError').style.display = 'none';
                document.getElementById('importSuccess').style.display = 'none';
                document.getElementById('importForm').reset();
            }
        }

        // Закрыть модальное окно импорта
        function closeImportModal() {
            console.log('[IMPORT] Закрытие модального окна импорта...');
            const modal = document.getElementById('importModal');
            if (modal) {
                modal.style.display = 'none';
            }
        }

        // Обработка формы импорта
        document.addEventListener('DOMContentLoaded', function() {
            const importForm = document.getElementById('importForm');
            if (importForm) {
                importForm.addEventListener('submit', async function(e) {
                    e.preventDefault();
                    console.log('[IMPORT] Начало импорта...');

                    const fileInput = document.getElementById('importFile');
                    const errorDiv = document.getElementById('importError');
                    const successDiv = document.getElementById('importSuccess');

                    if (!fileInput.files || fileInput.files.length === 0) {
                        errorDiv.textContent = 'Пожалуйста, выберите файл';
                        errorDiv.style.display = 'block';
                        successDiv.style.display = 'none';
                        console.error('[IMPORT ERROR] Файл не выбран');
                        return;
                    }

                    const formData = new FormData();
                    formData.append('file', fileInput.files[0]);

                    // Получаем токен CSRF
                    const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
                    if (token) {
                        formData.append('__RequestVerificationToken', token);
                    }

                    try {
                        errorDiv.style.display = 'none';
                        successDiv.style.display = 'none';
                        errorDiv.textContent = '';
                        successDiv.textContent = '';

                        const response = await fetch('/Home/ImportDeals', {
                            method: 'POST',
                            body: formData,
                            headers: {
                                'RequestVerificationToken': token || ''
                            }
                        });

                        const result = await response.json();
                        console.log('[IMPORT] Ответ сервера:', result);

                        if (result.success) {
                            successDiv.textContent = result.message || 'Данные успешно импортированы!';
                            successDiv.style.display = 'block';
                            console.log('[IMPORT SUCCESS]', result.message);
                            
                            // Перезагружаем страницу через 2 секунды
                            setTimeout(() => {
                                window.location.reload();
                            }, 2000);
                        } else {
                            errorDiv.textContent = result.message || 'Ошибка при импорте данных';
                            errorDiv.style.display = 'block';
                            console.error('[IMPORT ERROR]', result.message);
                        }
                    } catch (error) {
                        errorDiv.textContent = 'Ошибка при отправке файла: ' + error.message;
                        errorDiv.style.display = 'block';
                        console.error('[IMPORT ERROR]', error);
                    }
                });
            }

            // Закрытие модального окна при клике вне его
            const modal = document.getElementById('importModal');
            if (modal) {
                window.onclick = function(event) {
                    if (event.target === modal) {
                        closeImportModal();
                    }
                }
            }
        });
    </script>
</body>
</html>