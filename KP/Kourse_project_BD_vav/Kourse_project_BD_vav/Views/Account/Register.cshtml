@model Kourse_project_BD_vav.Models.RegisterModel

@{
    ViewData["Title"] = "Регистрация";
}

<!DOCTYPE html>
<html>
<head>
    <title>@ViewData["Title"]</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #e0e0e0 0%, #bdbdbd 100%);
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 20px;
        }

        @@keyframes slideDown {
            from {
                opacity: 0;
                transform: translateY(-20px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .register-container {
            background: white;
            padding: 40px;
            border-radius: 15px;
            box-shadow: 0 4px 30px rgba(0,0,0,0.1);
            width: 100%;
            max-width: 450px;
            animation: slideDown 0.5s ease;
        }

        .register-header {
            text-align: center;
            margin-bottom: 30px;
        }

        .register-header h2 {
            color: #343a40;
            margin-bottom: 10px;
            font-size: 28px;
        }

        .register-header p {
            color: #6c757d;
        }

        .form-group {
            margin-bottom: 20px;
        }

        label {
            display: block;
            margin-bottom: 8px;
            color: #495057;
            font-weight: 600;
        }

        input, select {
            width: 100%;
            padding: 12px 15px;
            border: 2px solid #e9ecef;
            border-radius: 10px;
            font-size: 16px;
            transition: all 0.3s ease;
            box-sizing: border-box;
        }

        input:focus, select:focus {
            border-color: #6c757d;
            outline: none;
            box-shadow: 0 0 0 3px rgba(108, 117, 125, 0.1);
        }

        .btn-register {
            width: 100%;
            padding: 15px;
            background: linear-gradient(135deg, #6c757d, #495057);
            color: white;
            border: none;
            border-radius: 10px;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
            margin-top: 10px;
        }

        .btn-register:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(108, 117, 125, 0.4);
        }

        .validation-error {
            color: #dc3545;
            font-size: 14px;
            margin-top: 5px;
        }

        .links {
            text-align: center;
            margin-top: 20px;
        }

        .links a {
            color: #495057;
            text-decoration: none;
            font-weight: 500;
            transition: color 0.3s;
        }

        .links a:hover {
            color: #343a40;
            text-decoration: underline;
        }

        .role-info {
            margin-top: 20px;
            padding: 15px;
            background: #f8f9fa;
            border-radius: 10px;
            font-size: 14px;
            border-left: 4px solid #6c757d;
        }

        .role-info h4 {
            margin-top: 0;
            margin-bottom: 15px;
            color: #343a40;
        }

        .role-item {
            margin-bottom: 8px;
            padding-left: 10px;
            color: #495057;
        }

        .role-item strong {
            color: #343a40;
        }
    </style>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
</head>
<body>
    <div class="register-container">
        <div class="register-header">
            <h2>Регистрация</h2>
            <p>Создайте новый аккаунт</p>
        </div>

        <form asp-controller="Account" asp-action="Register" method="post" enctype="application/x-www-form-urlencoded">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="All" class="validation-error"></div>
            <div class="form-group">
                <label asp-for="FullName">ФИО *</label>
                <input asp-for="FullName" name="FullName" id="FullName" placeholder="Иванов Иван Иванович" required />
                <span asp-validation-for="FullName" class="validation-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="Username">Имя пользователя *</label>
                <input asp-for="Username" name="Username" id="Username" placeholder="Придумайте имя пользователя" required />
                <span asp-validation-for="Username" class="validation-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="Email">Email *</label>
                <input asp-for="Email" name="Email" id="Email" type="email" placeholder="example@email.com" required />
                <span asp-validation-for="Email" class="validation-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="Password">Пароль *</label>
                <input asp-for="Password" name="Password" id="Password" type="password" placeholder="Минимум 6 символов" required />
                <span asp-validation-for="Password" class="validation-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="ConfirmPassword">Подтверждение пароля *</label>
                <input asp-for="ConfirmPassword" name="ConfirmPassword" id="ConfirmPassword" type="password" placeholder="Повторите пароль" required />
                <span asp-validation-for="ConfirmPassword" class="validation-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="Role">Роль *</label>
                <select asp-for="Role" name="Role" id="Role" required>
                    <option value="">-- Выберите роль --</option>
                    <option value="Client">Клиент</option>
                    <option value="Realtor">Риэлтор</option>
                </select>
                <span asp-validation-for="Role" class="validation-error"></span>
            </div>

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="validation-error">
                    @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                    {
                        <p>@error.ErrorMessage</p>
                    }
                </div>
            }

            <button type="submit" class="btn-register">Зарегистрироваться</button>
        </form>

        <div class="links">
            <a href="/Account/Login">Уже есть аккаунт? Войти</a> |
            <a href="/">На главную</a>
        </div>

        <div class="role-info">
            <h4>Описание ролей:</h4>
            <div class="role-item">
                <strong>Клиент</strong> - поиск недвижимости, просмотр сделок, личный кабинет
            </div>
            <div class="role-item">
                <strong>Риэлтор</strong> - управление объектами, работа с клиентами, создание сделок
            </div>
            <div class="role-item">
                <strong>Администратор</strong> - создается только системой, полный контроль
            </div>
        </div>
    </div>

    @section Scripts {
        <partial name="_ValidationScriptsPartial" />
    }
</body>
</html>
