@model Kourse_project_BD_vav.Models.LoginModel

@{
    ViewData["Title"] = "Вход в систему";
}

<!DOCTYPE html>
<html>
<head>
    <title>@ViewData["Title"]</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #e0e0e0 0%, #bdbdbd 100%);
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 20px;
        }

        @@keyframes slideDown {
            from {
                opacity: 0;
                transform: translateY(-20px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .login-container {
            background: white;
            padding: 40px;
            border-radius: 15px;
            box-shadow: 0 4px 30px rgba(0,0,0,0.1);
            width: 100%;
            max-width: 400px;
            animation: slideDown 0.5s ease;
        }

        .login-header {
            text-align: center;
            margin-bottom: 30px;
        }

        .login-header h2 {
            color: #343a40;
            margin-bottom: 10px;
            font-size: 28px;
        }

        .login-header p {
            color: #6c757d;
        }

        .form-group {
            margin-bottom: 20px;
        }

        label {
            display: block;
            margin-bottom: 8px;
            color: #495057;
            font-weight: 600;
        }

        input[type="text"],
        input[type="password"] {
            width: 100%;
            padding: 12px 15px;
            border: 2px solid #e9ecef;
            border-radius: 10px;
            font-size: 16px;
            transition: all 0.3s ease;
            box-sizing: border-box;
        }

        input[type="text"]:focus,
        input[type="password"]:focus {
            border-color: #6c757d;
            outline: none;
            box-shadow: 0 0 0 3px rgba(108, 117, 125, 0.1);
        }

        .checkbox-group {
            display: flex;
            align-items: center;
            margin-bottom: 20px;
        }

        .checkbox-group input {
            margin-right: 10px;
            width: auto;
        }

        .btn-login {
            width: 100%;
            padding: 15px;
            background: linear-gradient(135deg, #6c757d, #495057);
            color: white;
            border: none;
            border-radius: 10px;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
        }

        .btn-login:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(108, 117, 125, 0.4);
        }

        .validation-error {
            color: #dc3545;
            font-size: 14px;
            margin-top: 5px;
        }

        .links {
            text-align: center;
            margin-top: 20px;
        }

        .links a {
            color: #495057;
            text-decoration: none;
            margin: 0 10px;
            font-weight: 500;
            transition: color 0.3s;
        }

        .links a:hover {
            color: #343a40;
            text-decoration: underline;
        }
    </style>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
</head>
<body>
    <div class="login-container">
        <div class="login-header">
            <h2>Вход в систему</h2>
            <p>Введите свои учетные данные</p>
        </div>

        <form asp-controller="Account" asp-action="Login" method="post" enctype="application/x-www-form-urlencoded">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="All" class="validation-error"></div>

            <div class="form-group">
                <label asp-for="Username">Имя пользователя</label>
                <input asp-for="Username" name="Username" id="Username" type="text" placeholder="Введите имя пользователя" required />
                <span asp-validation-for="Username" class="validation-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="Password">Пароль</label>
                <input asp-for="Password" name="Password" id="Password" type="password" placeholder="Введите пароль" required />
                <span asp-validation-for="Password" class="validation-error"></span>
            </div>

            <div class="checkbox-group">
                <input asp-for="RememberMe" name="RememberMe" id="RememberMe" type="checkbox" />
                <label asp-for="RememberMe">Запомнить меня</label>
            </div>

            @if (!ViewData.ModelState.IsValid && ViewData.ModelState[string.Empty]?.Errors.Count > 0)
            {
                <div class="validation-error">
                    @ViewData.ModelState[string.Empty].Errors.First().ErrorMessage
                </div>
            }

            <button type="submit" class="btn-login">Войти</button>
        </form>

        <div class="links">
            <a href="/Account/Register">Регистрация</a> |
            <a href="/">На главную</a>
        </div>
    </div>

    @section Scripts {
        <partial name="_ValidationScriptsPartial" />
    }
</body>
</html>
