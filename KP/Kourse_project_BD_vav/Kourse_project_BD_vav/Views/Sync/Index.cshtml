@model Kourse_project_BD_vav.Interfaces.SyncStatus
@{
    ViewData["Title"] = "Синхронизация баз данных";
}

<!DOCTYPE html>
<html>
<head>
    <title>@ViewData["Title"]</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #e0e0e0 0%, #bdbdbd 100%);
            min-height: 100vh;
            padding: 20px;
        }

        .container {
            max-width: 1200px;
            margin: 0 auto;
        }

        @@keyframes slideDown {
            from {
                opacity: 0;
                transform: translateY(-20px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* Шапка */
        .header {
            background: white;
            padding: 20px 30px;
            border-radius: 15px;
            margin-bottom: 25px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            box-shadow: 0 4px 20px rgba(0,0,0,0.1);
            border-left: 5px solid #6c757d;
            animation: slideDown 0.5s ease;
        }

        .back-btn {
            padding: 10px 20px;
            background: #f8f9fa;
            color: #495057;
            text-decoration: none;
            border-radius: 8px;
            font-weight: 600;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            transition: all 0.3s ease;
        }

        .back-btn:hover {
            background: #e9ecef;
            transform: translateX(-3px);
            box-shadow: 0 2px 8px rgba(0,0,0,0.1);
        }

        /* Уведомления */
        .alert {
            padding: 15px 20px;
            border-radius: 10px;
            margin-bottom: 20px;
            font-weight: 500;
            animation: slideDown 0.5s ease;
        }

        /* Карточки */
        .card {
            background: white;
            border-radius: 15px;
            overflow: hidden;
            box-shadow: 0 4px 30px rgba(0,0,0,0.1);
            margin-bottom: 25px;
            animation: slideDown 0.7s ease;
        }

        .card-body {
            padding: 25px;
        }

        .card-title {
            color: #343a40;
            font-weight: 600;
            font-size: 18px;
            margin-bottom: 20px;
            border-bottom: 2px solid #e9ecef;
            padding-bottom: 10px;
        }

        /* Кнопки */
        .btn {
            padding: 15px 30px;
            border-radius: 10px;
            font-weight: 600;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 10px;
            border: none;
            cursor: pointer;
            transition: all 0.3s ease;
            font-size: 16px;
            color: white;
        }

        .btn-primary {
            background: linear-gradient(135deg, #27ae60, #219653);
        }

        .btn-primary:hover {
            transform: translateY(-3px);
            box-shadow: 0 6px 20px rgba(39, 174, 96, 0.4);
        }

        .btn-success {
            background: linear-gradient(135deg, #27ae60, #219653);
        }

        .btn-success:hover {
            transform: translateY(-3px);
            box-shadow: 0 6px 20px rgba(39, 174, 96, 0.4);
        }

        .btn-info {
            background: linear-gradient(135deg, #3498db, #2980b9);
        }

        .btn-info:hover {
            transform: translateY(-3px);
            box-shadow: 0 6px 20px rgba(52, 152, 219, 0.4);
        }

        /* Таблица */
        .table-container {
            overflow-x: auto;
        }

        table {
            width: 100%;
            border-collapse: collapse;
        }

        thead {
            background: #343a40;
            color: white;
        }

        th {
            padding: 15px;
            text-align: left;
            font-weight: 600;
            text-transform: uppercase;
            font-size: 12px;
            letter-spacing: 1px;
        }

        tbody tr {
            border-bottom: 1px solid #e9ecef;
            transition: all 0.2s ease;
        }

        tbody tr:hover {
            background: #f8f9fa;
            transform: scale(1.01);
        }

        td {
            padding: 15px;
            text-align: center;
        }

        .badge {
            padding: 5px 12px;
            border-radius: 12px;
            font-size: 12px;
            font-weight: 500;
            display: inline-block;
        }

        .bg-success {
            background: #28a745;
            color: white;
        }

        .bg-danger {
            background: #dc3545;
            color: white;
        }

        .bg-warning {
            background: #ffc107;
            color: #212529;
        }

        .bg-secondary {
            background: #6c757d;
            color: white;
        }

        .text-success {
            color: #28a745;
            font-weight: 600;
        }

        .text-danger {
            color: #dc3545;
            font-weight: 600;
        }

        .text-muted {
            color: #6c757d;
        }

        .small {
            font-size: 13px;
        }

        .row {
            display: flex;
            gap: 20px;
            margin-bottom: 15px;
        }

        .col-md-6 {
            flex: 1;
        }

        .d-flex {
            display: flex;
        }

        .justify-content-between {
            justify-content: space-between;
        }

        .align-items-center {
            align-items: center;
        }

        .mb-3 {
            margin-bottom: 15px;
        }

        .mb-4 {
            margin-bottom: 25px;
        }

        h1 {
            color: #343a40;
            margin-bottom: 20px;
        }

        .modal {
            display: none;
            position: fixed;
            z-index: 1000;
            left: 0;
            top: 0;
            width: 100%;
            height: 100%;
            overflow: auto;
            background-color: rgba(0,0,0,0.5);
        }

        .modal-content {
            background-color: #fefefe;
            margin: 10% auto;
            padding: 20px;
            border: 1px solid #888;
            width: 520px;
            border-radius: 10px;
            box-shadow: 0 4px 20px rgba(0,0,0,0.3);
        }

        .close {
            color: #aaa;
            font-size: 28px;
            font-weight: bold;
            cursor: pointer;
        }

        .close:hover {
            color: #000;
        }

        @@keyframes spin {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }
    </style>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
</head>
<body>
    <div class="container">
        <!-- Шапка -->
        <div class="header">
            <h1 style="margin: 0; color: #343a40; display: flex; align-items: center; gap: 10px;">Синхронизация баз данных</h1>
            <a href="/Home/Dashboard" class="back-btn">
                <i class="bi bi-arrow-left"></i> Назад в кабинет
            </a>
        </div>

        <!-- Уведомления -->
        @if (TempData["Message"] != null)
        {
            <div class="alert @(TempData["MessageType"]?.ToString() == "success" ? "alert-success" : "alert-error")">
                @TempData["Message"]
            </div>
        }
        @if (TempData["SyncMessage"] != null)
        {
            <div class="alert alert-success">
                @TempData["SyncMessage"]
            </div>
        }
        @if (TempData["SyncError"] != null)
        {
            <div class="alert alert-error">
                @TempData["SyncError"]
            </div>
        }

        <!-- Карточка статуса -->
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">Статус системы</h5>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <div class="d-flex justify-content-between align-items-center">
                            <span>MSSQL (Standby):</span>
                            @if (Model.MssqlConnected)
                            {
                                <span class="badge bg-success">Подключена</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Отключена</span>
                            }
                        </div>
                    </div>

                    <div class="col-md-6 mb-3">
                        <div class="d-flex justify-content-between align-items-center">
                            <span>PostgreSQL (Основная):</span>
                            @if (Model.PgConnected)
                            {
                                <span class="badge bg-success">Подключена</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Отключена</span>
                            }
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <div class="d-flex justify-content-between align-items-center">
                            <span>Последняя синхронизация:</span>
                            @if (Model.LastSync.HasValue)
                            {
                                <span class="text-success">@Model.LastSync.Value.ToString("dd.MM.yyyy HH:mm")</span>
                            }
                            else
                            {
                                <span class="text-danger">Никогда</span>
                            }
                        </div>
                    </div>

                    <div class="col-md-6 mb-3">
                        <div class="d-flex justify-content-between align-items-center">
                            <span>Всего записей:</span>
                            <span class="badge bg-secondary">@Model.TotalRecordsSynced</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Кнопки управления -->
        <div class="card">
            <div class="card-body" style="text-align: center;">
                <h5 class="card-title mb-4">Управление синхронизацией</h5>

                <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 20px;">
                    <div>
                        <button id="syncButton" class="btn btn-primary" style="width: 100%; padding: 20px;">
                            <i class="bi bi-arrow-repeat"></i>
                            <strong>СИНХРОНИЗАЦИЯ</strong>
                        </button>
                        <p class="text-muted" style="margin-top: 8px; font-size: 13px;">Двусторонняя синхронизация MSSQL и PostgreSQL</p>
                    </div>

                    <div>
                        <a href="@Url.Action("ExportDeals", "SyncPage")" class="btn btn-success" style="width: 100%; padding: 20px;">
                            <i class="bi bi-download"></i>
                            <strong>ЭКСПОРТ DEALS</strong>
                        </a>
                        <p class="text-muted" style="margin-top: 8px; font-size: 13px;">Экспорт таблицы Deals в JSON файл</p>
                    </div>

                    <div>
                        <button type="button" class="btn btn-info" style="width: 100%; padding: 20px;" onclick="showImportModal()">
                            <i class="bi bi-upload"></i>
                            <strong>ИМПОРТ DEALS</strong>
                        </button>
                        <p class="text-muted" style="margin-top: 8px; font-size: 13px;">Импорт таблицы Deals из JSON файла</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Таблица статуса -->
        <div class="card">
            <div class="card-body">
                <h5 class="card-title mb-4">Статус таблиц</h5>

                <div class="table-container">
                    <table>
                        <thead>
                            <tr>
                                <th>Таблица</th>
                                <th>MSSQL</th>
                                <th>PostgreSQL</th>
                                <th>Разница</th>
                                <th>Статус</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var table in Model.Tables)
                            {
                                <tr>
                                    <td><strong>@table.Name</strong></td>
                                    <td>
                                        <span class="badge bg-secondary">@table.MssqlCount</span>
                                    </td>
                                    <td>
                                        <span class="badge bg-secondary">@table.PgCount</span>
                                    </td>
                                    <td>
                                        <span class="badge @(table.Difference > 0 ? "bg-warning" : "bg-secondary")">
                                            @table.Difference
                                        </span>
                                    </td>
                                    <td>
                                        @if (table.IsSynced)
                                        {
                                            <span class="badge bg-success">Синхронизировано</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger">Требует синхронизации</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                        <tfoot style="background: #f8f9fa;">
                            <tr>
                                <td><strong>Итого:</strong></td>
                                <td>
                                    <strong>@Model.Tables.Sum(t => t.MssqlCount)</strong>
                                </td>
                                <td>
                                    <strong>@Model.Tables.Sum(t => t.PgCount)</strong>
                                </td>
                                <td>
                                    <strong>@Model.Tables.Sum(t => t.Difference)</strong>
                                </td>
                                <td>
                                    @{
                                        var syncedCount = Model.Tables.Count(t => t.IsSynced);
                                        var totalCount = Model.Tables.Count;
                                    }
                                    <span class="badge @(syncedCount == totalCount ? "bg-success" : "bg-danger")">
                                        @syncedCount / @totalCount
                                    </span>
                                </td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        </div>

        <div id="importModal" class="modal">
            <div class="modal-content">
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px;">
                    <h3 style="margin: 0; color: #2c3e50;">Импорт Deals из JSON</h3>
                    <span class="close" onclick="closeImportModal()">&times;</span>
                </div>

                <form action="@Url.Action("ImportDeals", "SyncPage")" method="post" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()
                    <div style="margin-bottom: 14px;">
                        <label for="importFile" style="display:block; margin-bottom: 8px; font-weight: 600;">Выберите JSON файл</label>
                        <input id="importFile" type="file" name="file" accept=".json" required style="width:100%; padding: 10px; border: 1px solid #ccc; border-radius: 8px;" />
                    </div>
                    <div style="margin-bottom: 16px; padding: 10px; background-color: #fff3cd; border-left: 4px solid #ffc107; color: #856404; font-size: 13px;">
                        Будут удалены текущие записи Deals и загружены данные из файла.
                    </div>
                    <div style="display:flex; justify-content:flex-end; gap: 10px;">
                        <button type="button" class="btn" style="background:#6c757d; padding:10px 14px;" onclick="closeImportModal()">Отмена</button>
                        <button type="submit" class="btn btn-info" style="padding:10px 14px;">Импортировать</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script>
        let isSyncing = false;

        // Кнопка синхронизации
        document.getElementById('syncButton')?.addEventListener('click', function() {
            if (isSyncing) return;

            if (!confirm('Запустить синхронизацию?\n\nБудет выполнена двусторонняя синхронизация между PostgreSQL и MSSQL.')) {
                return;
            }

            isSyncing = true;
            const button = this;
            const originalHtml = button.innerHTML;
            button.disabled = true;
            button.innerHTML = '<i class="bi bi-arrow-repeat" style="animation: spin 1s linear infinite;"></i> СИНХРОНИЗАЦИЯ...';

            // Отправляем POST запрос
            fetch('/Sync/Sync', {
                method: 'POST',
                headers: {
                    'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value || ''
                }
            })
            .then(response => {
                setTimeout(() => {
                    location.reload();
                }, 1000);
            })
            .catch(error => {
                alert('Ошибка: ' + error.message);
                button.disabled = false;
                button.innerHTML = originalHtml;
                isSyncing = false;
            });
        });

        function showImportModal() {
            const modal = document.getElementById('importModal');
            if (modal) {
                modal.style.display = 'block';
            }
        }

        function closeImportModal() {
            const modal = document.getElementById('importModal');
            if (modal) {
                modal.style.display = 'none';
            }
        }

        window.onclick = function(event) {
            const modal = document.getElementById('importModal');
            if (modal && event.target === modal) {
                closeImportModal();
            }
        }
    </script>
</body>
</html>
